PORT=5001
PUBLIC_SITE_URL=https://o2wedding.ru
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-1000000000000
# Optional: set only if you want notifications in a specific Telegram topic
# TELEGRAM_MESSAGE_THREAD_ID=123

# Optional: Yandex SmartCaptcha protection for the RSVP form
# If these keys are not set, the form works without captcha
# VITE_YANDEX_SMARTCAPTCHA_SITE_KEY=your_smartcaptcha_site_key
# YANDEX_SMARTCAPTCHA_SERVER_KEY=your_smartcaptcha_server_key

# Optional: PostgreSQL connection string
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional: Yandex Disk XLSX export for RSVP rows
# You need a user OAuth token with Disk access; client_id/client_secret alone are not enough
# YANDEX_DISK_OAUTH_TOKEN=your_yandex_disk_oauth_token
# YANDEX_DISK_FILE_PATH=disk:/Wedding RSVP/rsvps.xlsx
